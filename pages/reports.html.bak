<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IMS | Reports</title>

    <!-- CSS -->
    <link rel="stylesheet" href="../css/style.css">
    <link rel="stylesheet" href="../css/dashboard-theme.css">

    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Libraries -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        body { display: block; }

        .dashboard-container {
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        .main-content {
            flex: 1;
            overflow-y: auto;
            padding: 1.5rem 2rem;
        }

        .inventory-table-ultra-compact th,
        .inventory-table-ultra-compact td {
            padding: 0.15rem 0.3rem !important;
            line-height: 1 !important;
            font-size: 0.8rem !important;
        }
    </style>
</head>

<body>

    <!-- Background -->
    <div class="bg-image" style="background-image: url('../assets/inventory_system_background.png');"></div>

    <div class="dashboard-container">

        <!-- Sidebar (Updated to match dashboard/inventory styles) -->
<aside class="sidebar">
    <div class="title">
        <i class="fa-solid fa-cube"></i> Hisaab Kitab
        <span id="modeBadge" class="mode-badge">IMS Cloud</span>
    </div>

    <nav class="nav-menu">
        <a href="dashboard.html" class="nav-item" data-tab="dashboard">
            <i class="fa-solid fa-chart-line"></i> Dashboard
        </a>
        <a href="purchase.html" class="nav-item" data-tab="purchase">
            <i class="fa-solid fa-cart-shopping"></i> Purchase
        </a>
        <a href="sales.html" class="nav-item" data-tab="sales">
            <i class="fa-solid fa-cash-register"></i> Sales
        </a>
        <a href="expenses.html" class="nav-item" data-tab="expenses">
            <i class="fa-solid fa-money-bill-wave"></i> Expenses
        </a>
        <a href="inventory.html" class="nav-item" data-tab="inventory">
            <i class="fa-solid fa-boxes-stacked"></i> Inventory
        </a>
        <a href="reports.html" class="nav-item active" data-tab="reports">
            <i class="fa-solid fa-file-invoice"></i> Reports
        </a>
        <a href="admin.html" class="nav-item hidden" id="adminTab" data-tab="admin">
            <i class="fa-solid fa-users-gear"></i> Admin Panel
        </a>

        <div style="margin-top:auto;">
            <a href="#" class="nav-item" id="logoutBtn">
                <i class="fa-solid fa-right-from-bracket"></i> Logout
            </a>
        </div>
    </nav>
</aside>

<!-- Sidebar Overlay for Mobile -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

        <!-- Main -->
        <main class="main-content">

            <!-- Header (UNCHANGED LOOK) -->
            <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                <h2 id="pageTitle" style="font-size: 1.75rem;">Reports</h2>

                <div class="user-profile" style="display:flex; align-items:center; gap:1rem; cursor:pointer;"
                    onclick="openUserProfile()">
                    <span id="userNameDisplay">User Name</span>
                    <div style="width:40px; height:40px; background:var(--primary); border-radius:50%; display:flex; align-items:center; justify-content:center;">
                        <i class="fa-solid fa-user"></i>
                    </div>
                </div>
            </header>

            <!-- Reports -->
            <section id="reports" class="view-section">
                <div class="glass-card" style="max-width: 100%; padding:1.5rem;">

                    <!-- Filters (UNCHANGED) -->
                    <div style="display:flex; flex-wrap:wrap; gap:1rem; justify-content:space-between; align-items:flex-end; margin-bottom:2rem; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:1.5rem;">

                        <div style="display:flex; gap:1rem; flex-wrap:wrap; align-items:flex-end;">
                            
                            <div class="form-group" style="margin-bottom:0;">
                                <label>Report Type</label>
                                <select id="reportType" class="form-input" style="color:#333; background:white;">
                                    <option value="sales">Sales Report</option>
                                    <option value="purchase">Purchase Report</option>
                                    <option value="expenses">Expense Report</option>
                                    <option value="vendor">Vendor Report</option>
                                    <option value="item">Item/Inventory Report</option>
                                </select>
                            </div>

                            <div class="form-group" style="margin-bottom:0;">
                                <label>Frequency</label>
                                <select id="reportFreq" class="form-input" style="color:#333; background:white;">
                                    <option value="daily">Daily</option>
                                    <option value="weekly">Weekly</option>
                                    <option value="monthly" selected>Monthly</option>
                                </select>
                            </div>

                            <div class="form-group" style="margin-bottom:0;">
                                <label>Date</label>
                                <input type="date" id="reportDate" class="form-input">
                            </div>

                            <button class="btn" onclick="generateReport()">
                                <i class="fa-solid fa-filter"></i> Generate
                            </button>
                        </div>

                        <div style="display:flex; gap:0.5rem;">
                            <button class="btn" style="background:#ef4444;" onclick="downloadPDF()">
                                <i class="fa-solid fa-file-pdf"></i> PDF
                            </button>
                            <button class="btn" style="background:#22c55e;" onclick="window.print()">
                                <i class="fa-solid fa-print"></i> Print
                            </button>
                        </div>
                    </div>

                    <!-- Title -->
                    <h3 id="reportTitleDisplay" style="margin-bottom: 1rem; color:#60a5fa;">
                        Monthly Sales Report
                    </h3>

                    <!-- Summary -->
                    <div class="stat-grid"
                        style="grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:1rem; margin-bottom:1.5rem;"
                        id="reportSummary">
                    </div>

                    <!-- ✅ NEW CHART (ADDED ONLY) -->
                    <div style="height:280px; margin-bottom:1.5rem;">
                        <canvas id="reportChart"></canvas>
                    </div>

                    <!-- Table -->
                    <div style="overflow-x:auto; max-height:55vh;">
                        <table class="data-table">
                            <thead id="reportThead"></thead>
                            <tbody id="reportTbody">
                                <tr>
                                    <td colspan="10" style="text-align:center; padding:2rem; color:#aaa;">
                                        Select filters and click Generate
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                </div>
            </section>

        </main>
    </div>

    <!-- Scripts -->
    <script src="../js/api.js"></script>
    <script src="../js/app.js"></script>
    <script src="../js/admin.js"></script>
    <script src="../js/reports.js"></script>

</body>
</html>