<!-- CSS (MATCHES YOUR THEME & GLASS EFFECT) -->
<style>
.about-section {
    width: 100%;
    min-height: 100vh;
    padding: 50px 30px;
    background: url('../images/bg-pattern.png') center/cover no-repeat; /* match your site bg */
}

.about-wrapper {
    max-width: 1200px;
    margin: auto;
}

.about-header {
    text-align: center;
    margin-bottom: 50px;
}

.about-header .title {
    font-size: 2.5rem;
    color: var(--primary-orange);
}

.about-header .subtitle {
    font-size: 1.2rem;
    color: var(--text-dim);
}

/* About grid with glass effect */
.about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
    padding: 40px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(12px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.1);
}

.about-text h2 {
    font-size: 1.8rem;
    margin-bottom: 15px;
}

.about-text p {
    color: var(--text-dim);
    line-height: 1.7;
    margin-bottom: 12px;
    font-size: 15px;
}

.about-image img {
    width: 100%;
    max-width: 300px;
    display: block;
    margin: auto;
}

/* Features grid */
.features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 25px;
    margin-top: 60px;
}

.feature-card {
    padding: 25px;
    border-radius: 18px;
    text-align: center;
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(10px);
    transition: all 0.3s ease;
}

.feature-card:hover {
    transform: translateY(-6px);
    background: rgba(255,255,255,0.2);
}

.feature-card .icon {
    font-size: 30px;
    margin-bottom: 12px;
}

.feature-card h3 {
    margin-bottom: 8px;
    font-size: 1.2rem;
}

.feature-card p {
    font-size: 14px;
    color: var(--text-dim);
}

/* Responsive */
@media (max-width: 768px) {
    .about-grid {
        grid-template-columns: 1fr;
        text-align: center;
    }
    .about-image {
        margin-top: 20px;
    }
}
</style>