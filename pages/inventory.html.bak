<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>IMS | Inventory</title>

  <!-- Existing Theme CSS -->
  <link rel="stylesheet" href="../css/style.css">
  <link rel="stylesheet" href="../css/dashboard-theme.css">

  <!-- Fonts & Icons -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <!-- Libraries -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

  <style>
    /* Keep your existing theme but refine layout for professional look */

    /* Make sidebar fixed and main content full width */
    .dashboard-container {
      display: flex;
      height: 100vh;
      overflow: hidden;
    }

    .main-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow-y: auto;
      padding: 1.5rem 2rem;
    }

    /* Header refinements */
    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
    }

    .user-profile {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      cursor: pointer;
    }

    .user-profile .avatar {
      background-color: var(--primary-color, #3b82f6);
      width: 40px;
      height: 40px;
      border-radius: 50%;
      display: flex;
      justify-content: center;
      align-items: center;
      color: #fff;
    }

    /* Inventory cards and table */
    .glass-card {
      margin-bottom: 2rem;
      padding: 1.5rem;
      border-radius: 12px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
      background: rgba(30, 41, 59, 0.7);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: #e2e8f0;
      max-width: 100%; /* Override 400px from style.css */
    }

    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
    }

    .card-search input {
      width: 100%;
      padding: 0.5rem 1rem;
      border-radius: 6px;
      border: 1px solid #d1d5db;
      margin-bottom: 1rem;
    }

    .table-container {
      max-height: 450px;
      overflow-y: auto;
      overflow-x: auto;
      border-radius: 8px;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    table.data-table {
      width: 100%;
      min-width: max-content;
    }

    table.data-table th,
    table.data-table td {
      padding: 0.4rem 0.6rem;
      text-align: left;
      vertical-align: middle;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      font-size: 0.85rem;
      white-space: nowrap;
    }

    table.data-table th {
      font-weight: 600;
      position: sticky;
      top: 0;
      z-index: 1;
    }

    /* Chart container */
    .inventory-chart {
      height: 300px;
      margin-bottom: 2rem;
    }

    /* Edit Form */
    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .form-input {
      width: 100%;
      padding: 0.5rem 0.7rem;
      border-radius: 6px;
      border: 1px solid #d1d5db;
    }

    button.btn {
      border: none;
      cursor: pointer;
      padding: 0.5rem 1rem;
      border-radius: 6px;
      transition: 0.2s;
      vertical-align: middle;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    button.btn:hover {
      opacity: 0.9;
    }

    button.btn-sm {
      padding: 0.3rem 0.6rem;
      font-size: 0.9rem;
    }
  </style>
</head>

<body>
  <!-- Reuse Background -->
  <div class="bg-image" style="background-image: url('../assets/inventory_system_background.png');"></div>

  <div class="dashboard-container">

    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="title">
        <i class="fa-solid fa-cube"></i> IMS Cloud
        <span id="modeBadge" class="mode-badge">DEMO</span>
      </div>
      <nav class="nav-menu">
        <a href="dashboard.html" class="nav-item"><i class="fa-solid fa-chart-line"></i> Dashboard</a>
        <a href="purchase.html" class="nav-item"><i class="fa-solid fa-cart-shopping"></i> Purchase</a>
        <a href="sales.html" class="nav-item"><i class="fa-solid fa-cash-register"></i> Sales</a>
        <a href="expenses.html" class="nav-item"><i class="fa-solid fa-money-bill-wave"></i> Expenses</a>
        <a href="inventory.html" class="nav-item active"><i class="fa-solid fa-boxes-stacked"></i> Inventory</a>
        <a href="reports.html" class="nav-item"><i class="fa-solid fa-file-invoice"></i> Reports</a>
        <a href="admin.html" class="nav-item hidden" id="adminTab"><i class="fa-solid fa-users-gear"></i> Admin Panel</a>
        <div style="margin-top:auto;">
          <a href="#" class="nav-item" id="logoutBtn"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
        </div>
      </nav>
    </aside>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Main -->
    <main class="main-content">

      <!-- Header -->
      <header class="page-header">
        <h2>Inventory</h2>
        <div class="user-profile" onclick="openUserProfile()">
          <span id="userNameDisplay">User Name</span>
          <div class="avatar"><i class="fa-solid fa-user"></i></div>
        </div>
      </header>
	  
	  <header class="page-header">
		<button id="sidebarToggle" class="hamburger">
		<i class="fa-solid fa-bars"></i>
		</button>
		<h2>Inventory</h2>
		<div class="user-profile" onclick="openUserProfile()">
		<span id="userNameDisplay">User Name</span>
		<div class="avatar"><i class="fa-solid fa-user"></i></div>
		</div>
	  </header>

      <!-- Inventory Chart -->
      <div class="glass-card">
        <h3>Inventory Overview</h3>
        <canvas id="inventoryChart" class="inventory-chart"></canvas>
      </div>

      <!-- Inventory Table -->
      <div class="glass-card">
        <div class="card-header">
          <h3>Available Inventory</h3>
          <div class="card-actions">
            <button id="downloadInventoryTemplate" class="btn btn-sm"><i class="fa-solid fa-download"></i> Template</button>
            <input type="file" id="importExcelInput" hidden>
            <button class="btn btn-sm" onclick="document.getElementById('importExcelInput').click()"><i class="fa-solid fa-file-excel"></i> Import</button>
            <button id="exportInventoryCsv" class="btn btn-warning btn-sm"><i class="fa-solid fa-file-export"></i> Export</button>
          </div>
        </div>
        <div class="card-search">
          <input type="text" id="inventorySearch" placeholder="Search inventory...">
        </div>
        <div class="table-container">
          <table class="data-table">
            <thead>
              <tr id="inventoryHeaderRow"></tr>
            </thead>
            <tbody id="inventoryTableBody"></tbody>
          </table>
        </div>
      </div>

      <!-- Edit Inventory Panel -->
      <div class="glass-card">
        <h3><i class="fa-solid fa-pen-to-square"></i> Edit Item</h3>
        <div class="edit-search-container">
          <input type="text" id="searchEditId" class="form-input" placeholder="Enter ID...">
          <button class="btn btn-primary btn-sm" onclick="searchInventoryForEdit()">Search</button>
        </div>

        <form id="editInventoryForm" class="hidden" onsubmit="event.preventDefault(); submitEditInventory();">
          <div id="editDynamicFieldsContainer" class="form-grid"></div>
          <button type="submit" class="btn btn-success">Update</button>
        </form>
      </div>

    </main>
  </div>

  <!-- Scripts -->
  <script src="../js/api.js"></script>
  <script src="../js/app.js"></script>
  <script src="../js/inventory.js"></script>
  <script>
    // Populate username dynamically
    async function loadUserName() {
      const user = JSON.parse(localStorage.getItem('currentUser') || '{}');
      document.getElementById('userNameDisplay').innerText = user['Full Name'] || user.username || 'User';
    }
    loadUserName();

    // Inventory Chart
    const ctx = document.getElementById('inventoryChart').getContext('2d');
    const inventoryChart = new Chart(ctx, {
      type: 'bar',
      data: { labels: [], datasets: [{ label: 'Quantity', data: [], backgroundColor: '#3b82f6' }] },
      options: {
        responsive: true,
        plugins: { legend: { display: false }, tooltip: { mode: 'index', intersect: false } },
        scales: { x: { title: { display: true, text: 'Category' } }, y: { beginAtZero: true, title: { display: true, text: 'Quantity' } } }
      }
    });

    // Load inventory chart from API
    async function loadInventoryChart() {
      const res = await fetch(`${API_URL}?action=getInventory`);
      const data = await res.json();
      const categories = [...new Set(data.map(d => d.Category))];
      const totals = categories.map(cat => data.filter(i => i.Category === cat).reduce((a, b) => a + Number(b.Quantity || 0), 0));
      inventoryChart.data.labels = categories;
      inventoryChart.data.datasets[0].data = totals;
      inventoryChart.update();
    }
    loadInventoryChart();
  </script>
</body>

</html>