<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>IMS | Dashboard</title>

  <!-- Theme & Fonts -->
  <link rel="stylesheet" href="../css/style.css">
  <link rel="stylesheet" href="../css/dashboard-theme.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <!-- Libraries -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

  <style>
    /* Dashboard Layout */
    .dashboard-container {
      display: flex;
      height: 100vh;
      overflow: hidden;
    }

    .main-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow-y: auto;
      padding: 1.5rem 2rem;
    }

    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
    }

    .user-profile {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      cursor: pointer;
    }

    .user-profile .avatar {
      background-color: var(--primary-color, #3b82f6);
      width: 40px;
      height: 40px;
      border-radius: 50%;
      display: flex;
      justify-content: center;
      align-items: center;
      color: #fff;
    }

    .glass-card {
      padding: 1.5rem;
      border-radius: 12px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
      background: rgba(30, 41, 59, 0.7);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: #e2e8f0;
      margin-bottom: 1.5rem;
    }

    .stat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .quick-actions {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .chart-row {
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
      margin-bottom: 2rem;
    }

    .chart-col {
      flex: 1;
      min-width: 280px;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .chart-container-fixed {
      width: 100%;
      height: 250px;
    }

    table.data-table th,
    table.data-table td {
      padding: 0.4rem 0.6rem;
      text-align: left;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      font-size: 0.85rem;
      white-space: nowrap;
    }

    table.data-table th {
      font-weight: 600;
      position: sticky;
      top: 0;
      z-index: 1;
    }

    #broadcastContainer {
      display: flex;
	  border: 2px solid orange;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
      background: rgba(55, 65, 81, 0.8);
      color: #f1f5f9;
      border-radius: 8px;
      margin-bottom: 1.5rem;
      font-weight: 500;
    }
  </style>
</head>

<body>
  <!-- Background -->
  <div class="bg-image" style="background-image: url('../assets/inventory_system_background.png');"></div>

  <div class="dashboard-container">

    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="title">
        <i class="fa-solid fa-cube"></i> IMS Cloud
        <span id="modeBadge" class="mode-badge">DEMO</span>
      </div>
      <nav class="nav-menu">
        <a href="dashboard.html" class="nav-item active"><i class="fa-solid fa-chart-line"></i> Dashboard</a>
        <a href="purchase.html" class="nav-item"><i class="fa-solid fa-cart-shopping"></i> Purchase</a>
        <a href="sales.html" class="nav-item"><i class="fa-solid fa-cash-register"></i> Sales</a>
        <a href="expenses.html" class="nav-item"><i class="fa-solid fa-money-bill-wave"></i> Expenses</a>
        <a href="inventory.html" class="nav-item"><i class="fa-solid fa-boxes-stacked"></i> Inventory</a>
        <a href="reports.html" class="nav-item"><i class="fa-solid fa-file-invoice"></i> Reports</a>
        <a href="admin.html" class="nav-item hidden" id="adminTab"><i class="fa-solid fa-users-gear"></i> Admin Panel</a>
        <div style="margin-top:auto;">
          <a href="#" class="nav-item" id="logoutBtn"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
        </div>
      </nav>
    </aside>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Main Content -->
    <main class="main-content">
      <!-- Header -->
      <header class="page-header">
        <h2>Dashboard</h2>
        <div class="user-profile" onclick="openUserProfile()">
          <span id="userNameDisplay">User Name</span>
          <div class="avatar"><i class="fa-solid fa-user"></i></div>
        </div>
      </header>

            

      <!-- Four Stat Boxes -->
<div class="stat-grid section-spacing">
  <div class="stat-card blue">
    <div class="stat-content">
	  <div class="stat-label">Inventory Status</div>
      <div class="stat-value">$50K <span class="stat-link">View Details</span></div>
      
    </div>
  </div>
  <div class="stat-card teal">
    <div class="stat-content">
      <div class="stat-value">$100K <span class="stat-link">View Details</span></div>
      <div class="stat-label">Revenue</div>
    </div>
  </div>
  <div class="stat-card yellow">
    <div class="stat-content">
      <div class="stat-value">515 <span class="stat-link">Visit Inventory</span></div>
      <div class="stat-label">Items Available</div>
    </div>
  </div>
  <div class="stat-card red">
    <div class="stat-content">
      <div class="stat-value">2 <span class="stat-link">Resolve Now</span></div>
      <div class="stat-label">Items Shortage</div>
    </div>
  </div>
</div>

<!-- Broadcast Scroll Bar -->
<div id="broadcastContainer" class="broadcast-container section-spacing">
  <div class="broadcast-icon"><i class="fa-solid fa-bullhorn"></i></div>
  <div class="broadcast-wrapper">
    <div class="broadcast-content" id="broadcastText">
      Welcome to IMS Cloud! &nbsp;|&nbsp; System Running Smoothly &nbsp;|&nbsp; New Sales Recorded!
    </div>
  </div>
</div>

<!-- Quick Actions -->
<div class="quick-actions-grid section-spacing">
  <div class="quick-action blue" data-target="purchase.html">New Purchase <i class="fa-solid fa-cart-shopping"></i></div>
  <div class="quick-action green" data-target="sales.html">New Sale <i class="fa-solid fa-cash-register"></i></div>
  <div class="quick-action orange" data-target="expenses.html">Add Expense <i class="fa-solid fa-money-bill-wave"></i></div>
  <div class="quick-action purple" data-target="inventory.html">Inventory <i class="fa-solid fa-boxes-stacked"></i></div>
  <div class="quick-action red" data-target="reports.html">Report <i class="fa-solid fa-file-invoice"></i></div>
</div>

      

      <!-- Charts & Low Stock -->
      <div class="chart-row section-spacing">
        <div class="chart-col">
          <div class="glass-card chart-container-fixed">
            <h3>Total Sale</h3>
            <canvas id="pharaSalesChart"></canvas>
          </div>
          <div class="glass-card">
            <h3 style="color:#f59e0b;"><i class="fa-solid fa-triangle-exclamation"></i> Low Stock Alerts</h3>
			<div id="topSellingList"><p style="color:#aaa;">Working On It</p></div>
            <table class="data-table">
              <tbody id="lowStockTableBody">
                <tr>
                  
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="chart-col">
  <!-- Credit Chart -->
  <div class="glass-card chart-container-fixed">
    <h3>Credit/Udhaar Tracking</h3>
    <canvas id="pharaCreditChart"></canvas>
  </div>

  <!-- ✅ NEW: Recent Activity -->
  <div class="glass-card">
    <h3 style="color:#38bdf8;">
      <i class="fa-solid fa-clock"></i> Recent Activity
    </h3>

    <div id="recentActivity">
      <ul style="list-style:none; padding:0; margin:0; font-size:0.9rem;">
        <li style="padding:6px 0; border-bottom:1px solid rgba(255,255,255,0.1);">
          🧾 Sale recorded - Rs 5,000
        </li>
        <li style="padding:6px 0; border-bottom:1px solid rgba(255,255,255,0.1);">
          📦 Purchase added - 20 items
        </li>
        <li style="padding:6px 0;">
          💸 Expense added - Rs 1,200
        </li>
      </ul>
    </div>
  </div>
</div>

        <div class="chart-col">
          <div class="glass-card chart-container-fixed">
            <h3>Inventory</h3>
            <canvas id="pharaInventoryChart"></canvas>
          </div>
          <div class="glass-card">
            <h3 style="color:#22c55e;"><i class="fa-solid fa-arrow-trend-up"></i> Top Selling Products</h3>
            <div id="topSellingList"><p style="color:#aaa;">No sales data available</p></div>
          </div>
        </div>
      </div>

      <!-- Dashboard Banner -->
      <div id="dashboardBannerContainer" style="width:100%; display:flex; justify-content:center; margin-bottom:2rem;">
        <!-- Injected via JS -->
      </div>

    </main>
  </div>

  <!-- Your other scripts -->
<script src="../js/api.js"></script>
<script src="../js/app.js"></script>
<script src="../js/admin.js"></script>

<!-- Quick Actions JS -->
<script>
  document.querySelectorAll('.quick-action').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.target;
      window.location.href = target; // redirect to relevant section/page
    });
  });
  
  const broadcastText = document.getElementById('broadcastText');

const messages = [
  "Welcome to IMS Cloud!",
  "System Running Smoothly",
  "New Sales Recorded!",
  "Check Inventory Updates!"
];

// Duplicate for smooth loop
const fullText = messages.join("   |   ");
broadcastText.innerHTML = fullText + "   |   " + fullText;

// Join messages with separators
broadcastText.innerHTML = messages.join(" &nbsp;|&nbsp; ");
</script>
</body>
</html>