(() => {
    // ===============================
    // Report PDF Download
    // ===============================
    const downloadPDF = () => {
        const original = document.querySelector('#reports .glass-card');
        if (!original || document.querySelector('#reportTbody').children.length === 0) {
            alert("Please generate a report first.");
            return;
        }

        const type = document.getElementById('reportType').value;
        const freq = document.getElementById('reportFreq').value;
        const dateVal = document.getElementById('reportDate').value || 'AllTime';

        const opt = {
            margin: 0.5,
            filename: `Report_${type}_${freq}_${dateVal}.pdf`,
            image: { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 2 },
            jsPDF: { unit: 'in', format: 'letter', orientation: 'landscape' }
        };

        // Clone report card and remove controls
        const clone = original.cloneNode(true);
        const controls = clone.querySelector('div[style*="justify-content: space-between"]');
        if (controls) controls.remove();

        // Add header
        const header = document.createElement('div');
        header.innerHTML = `
            <h2>Inventory System Report</h2>
            <p>Generated on ${new Date().toLocaleString()}</p>
            <hr>
        `;
        header.style.marginBottom = '20px';
        header.style.textAlign = 'center';
        clone.insertBefore(header, clone.firstChild);

        html2pdf().set(opt).from(clone).save();
    };

    // ===============================
    // DOMContentLoaded
    // ===============================
    document.addEventListener('DOMContentLoaded', () => {
        // Default date = today
        const dateInput = document.getElementById('reportDate');
        if (dateInput) dateInput.valueAsDate = new Date();

        // Report type change listener
        document.getElementById('reportType')?.addEventListener('change', handleReportTypeChange);
    });

    // ===============================
    // Handle Report Type Change
    // ===============================
    const handleReportTypeChange = async () => {
        const type = document.getElementById('reportType').value;
        const freqSelect = document.getElementById('reportFreq');

        // Reset freq options
        freqSelect.innerHTML = `
            <option value="daily">Daily</option>
            <option value="weekly">Weekly</option>
            <option value="monthly" selected>Monthly</option>
        `;

        // Vendor-specific options
        if (type === 'vendor') {
            try {
                const inventory = await API.getInventory();
                const vendors = [...new Set(inventory.map(i => i['Vendor'] || i.vendor).filter(Boolean))];

                if (vendors.length) {
                    const sep = document.createElement('option');
                    sep.disabled = true;
                    sep.innerText = "─── Specific Vendors ───";
                    freqSelect.appendChild(sep);

                    vendors.sort().forEach(v => {
                        const opt = document.createElement('option');
                        opt.value = `VAL_${v}`;
                        opt.innerText = v;
                        freqSelect.appendChild(opt);
                    });
                }
            } catch (e) {
                console.error("Error fetching vendors:", e);
            }
        }
    };

    // ===============================
    // Generate Report
    // ===============================
    const generateReport = async (event) => {
        const type = document.getElementById('reportType').value;
        const freqValue = document.getElementById('reportFreq').value;
        const dateVal = document.getElementById('reportDate').value;

        if (!dateVal) {
            alert("Please select a date.");
            return;
        }

        let freq = freqValue;
        let specificVendor = null;

        // Check for vendor selection
        if (freqValue.startsWith('VAL_')) {
            specificVendor = freqValue.substring(4);
            freq = 'monthly';
        }

        // Update report title
        const typeLabel = document.querySelector(`#reportType option[value="${type}"]`).text;
        const freqLabel = specificVendor || document.querySelector(`#reportFreq option[value="${freqValue}"]`).text;
        document.getElementById('reportTitleDisplay').textContent = `${freqLabel} ${typeLabel}`;

        // Fetch data
        let data = [];
        try {
            switch (type) {
                case 'sales':
                    data = await API.getSales();
                    break;
                case 'purchase':
                case 'vendor':
                    data = await API.getInventory();
                    break;
                case 'expenses':
                    data = await API.getExpenses();
                    break;
                case 'item':
                    const [inv, sal] = await Promise.all([API.getInventory(), API.getSales()]);
                    data = { inventory: inv, sales: sal };
                    break;
            }
        } catch (e) {
            console.error("Failed to fetch data:", e);
            alert("Failed to load data.");
            return;
        }

        // Process report
        let reportData = [];
        const dateObj = new Date(dateVal);

        if (type === 'item') reportData = processItemReport(data, freq, dateObj);
        else if (type === 'vendor') {
            reportData = specificVendor ? processSpecificVendorReport(data, specificVendor, freq, dateObj)
                                        : processVendorReport(data, freq, dateObj);
        } else {
            reportData = filterByDate(data, getDateField(type), freq, dateObj);
        }

        // Render summary & table
        if (specificVendor) {
            renderSummary('purchase', reportData);
            renderTable('purchase', reportData);
        } else {
            renderSummary(type, reportData);
            renderTable(type, reportData);
        }
    };

    // ===============================
    // Filtering Utilities
    // ===============================
    const filterByDate = (data, dateKey, freq, targetDate) => {
        return data.filter(item => {
            let itemDateStr = item[dateKey] || item.date || item.Date;
            if (!itemDateStr) return false;
            if (itemDateStr.includes('T')) itemDateStr = itemDateStr.split('T')[0];

            const itemDate = new Date(itemDateStr);
            const target = new Date(targetDate);
            itemDate.setHours(0,0,0,0);
            target.setHours(0,0,0,0);

            if (freq === 'daily') return itemDate.getTime() === target.getTime();
            if (freq === 'weekly') return getWeekNumber(itemDate).join() === getWeekNumber(target).join();
            if (freq === 'monthly') return itemDate.getMonth() === target.getMonth() && itemDate.getFullYear() === target.getFullYear();
            return false;
        });
    };

    const getWeekNumber = d => {
        d = new Date(Date.UTC(d.getFullYear(), d.getMonth(), d.getDate()));
        d.setUTCDate(d.getUTCDate() + 4 - (d.getUTCDay()||7));
        const yearStart = new Date(Date.UTC(d.getUTCFullYear(),0,1));
        return [d.getUTCFullYear(), Math.ceil((((d - yearStart)/86400000)+1)/7)];
    };

    const getDateField = type => type === 'purchase' ? 'Date' : 'date';

    // ===============================
    // Report Processors
    // ===============================
    const processSpecificVendorReport = (data, vendor, freq, targetDate) => {
        const filtered = data.filter(item => (item['Vendor'] || item.vendor) === vendor);
        return filterByDate(filtered, 'Date', freq, targetDate);
    };

    const processVendorReport = (data, freq, targetDate) => {
        const filtered = filterByDate(data, 'Date', freq, targetDate);
        const map = {};
        filtered.forEach(p => {
            const v = p['Vendor'] || p.vendor || 'Unknown';
            if (!map[v]) map[v] = { name: v, count: 0, total: 0, paid: 0 };
            map[v].count += parseFloat(p['Quantity'] || p.qty) || 0;
            map[v].total += parseFloat(p['Total'] || p.total) || 0;
            map[v].paid += parseFloat(p['Paid'] || p.paid) || 0;
        });
        return Object.values(map);
    };

    const processItemReport = (data, freq, targetDate) => {
        const filtered = filterByDate(data.sales, 'date', freq, targetDate);
        const map = {};
        filtered.forEach(s => {
            const item = s['Item Name'] || s.item || 'Unknown';
            if (!map[item]) map[item] = { name: item, qtySold: 0, revenue: 0 };
            map[item].qtySold += parseFloat(s.quantity || s.qty) || 0;
            map[item].revenue += parseFloat(s.total) || 0;
        });
        return Object.values(map).sort((a,b)=>b.revenue - a.revenue);
    };

    // ===============================
    // Rendering Functions
    // ===============================
    const renderSummary = (type, data) => {
        const container = document.getElementById('reportSummary');
        if (!container) return;

        let stats = [];
        switch (type) {
            case 'sales':
                const total = data.reduce((a,c)=>a+(parseFloat(c.total)||0),0);
                const cashTotal = data.filter(d=>d.mode?.toLowerCase()==='cash').reduce((a,c)=>a+(parseFloat(c.total)||0),0);
                stats = [
                    { label:'Total Sales', value:formatCurrency(total), color:'blue' },
                    { label:'Transactions', value:data.length, color:'orange' },
                    { label:'Cash Sales', value:formatCurrency(cashTotal), color:'green' }
                ]; break;
            case 'purchase':
                const totalP = data.reduce((a,c)=>a+(parseFloat(c['Total']||c.total)||0),0);
                const balance = data.reduce((a,c)=>a+(parseFloat(c['Balance']||c.balance)||0),0);
                stats = [
                    { label:'Total Purchases', value:formatCurrency(totalP), color:'blue' },
                    { label:'Items Purchased', value:data.length, color:'orange' },
                    { label:'Unpaid Balance', value:formatCurrency(balance), color:'red' }
                ]; break;
            case 'expenses':
                const totalE = data.reduce((a,c)=>a+parseFloat(c.amount||0),0);
                stats = [
                    { label:'Total Expenses', value:formatCurrency(totalE), color:'red' },
                    { label:'Count', value:data.length, color:'orange' }
                ]; break;
            case 'vendor':
                const totalV = data.reduce((a,c)=>a+c.total,0);
                stats = [
                    { label:'Total Purchased', value:formatCurrency(totalV), color:'blue' },
                    { label:'Active Vendors', value:data.length, color:'green' }
                ]; break;
            case 'item':
                const rev = data.reduce((a,c)=>a+c.revenue,0);
                const qty = data.reduce((a,c)=>a+c.qtySold,0);
                stats = [
                    { label:'Total Revenue', value:formatCurrency(rev), color:'blue' },
                    { label:'Units Sold', value:qty, color:'orange' }
                ]; break;
        }

        container.innerHTML = stats.map(s => `
            <div class="stat-card ${s.color}">
                <div class="stat-content" style="padding:0;">
                    <div class="stat-label">${s.label}</div>
                    <div class="stat-value" style="font-size:1.2rem;">${s.value}</div>
                </div>
            </div>
        `).join('');
    };

    const renderTable = (type, data) => {
        const thead = document.getElementById('reportThead');
        const tbody = document.getElementById('reportTbody');
        if (!thead || !tbody) return;

        if (!data.length) {
            tbody.innerHTML = `<tr><td colspan="10" style="text-align:center;padding:2rem;">No Records Found</td></tr>`;
            return;
        }

        let headers = [], rows = '';
        switch(type) {
            case 'sales':
                headers = ['Date','Customer','Item','Qty','Price','Total','Mode'];
                rows = data.map(d=>`
                    <tr>
                        <td>${formatDate(d.date)}</td>
                        <td>${d.customer||'-'}</td>
                        <td>${d['Item Name']||d.item}</td>
                        <td>${d.quantity||d.qty}</td>
                        <td>${d.price}</td>
                        <td>${d.total}</td>
                        <td>${d.mode||'-'}</td>
                    </tr>
                `).join(''); break;
            case 'purchase':
                headers = ['Date','Vendor','Item','Qty','Total','Balance'];
                rows = data.map(d=>`
                    <tr>
                        <td>${formatDate(d['Date']||d.date)}</td>
                        <td>${d['Vendor']||d.vendor}</td>
                        <td>${d['Item Name']||d.item}</td>
                        <td>${d['Quantity']||d.qty}</td>
                        <td>${d['Total']||d.total}</td>
                        <td style="color:${(d['Balance']||d.balance)>0?'red':'green'}">${d['Balance']||d.balance}</td>
                    </tr>
                `).join(''); break;
            case 'expenses':
                headers = ['Date','Title','Desc','Amount','Mode'];
                rows = data.map(d=>`
                    <tr>
                        <td>${formatDate(d.date)}</td>
                        <td>${d.title||d.category||'-'}</td>
                        <td>${d.description||d.desc||'-'}</td>
                        <td>${d.amount}</td>
                        <td>${d.mode||'-'}</td>
                    </tr>
                `).join(''); break;
            case 'vendor':
                headers = ['Vendor Name','Items Qty','Total Amount','Amount Paid'];
                rows = data.map(d=>`
                    <tr>
                        <td>${d.name}</td>
                        <td>${d.count}</td>
                        <td>${formatCurrency(d.total)}</td>
                        <td>${formatCurrency(d.paid)}</td>
                    </tr>
                `).join(''); break;
            case 'item':
                headers = ['Item Name','Qty Sold','Revenue Generated'];
                rows = data.map(d=>`
                    <tr>
                        <td>${d.name}</td>
                        <td>${d.qtySold}</td>
                        <td>${formatCurrency(d.revenue)}</td>
                    </tr>
                `).join(''); break;
        }

        thead.innerHTML = `<tr>${headers.map(h=>`<th>${h}</th>`).join('')}</tr>`;
        tbody.innerHTML = rows;
    };

    // ===============================
    // Utilities
    // ===============================
    const formatCurrency = val => 'Rs. ' + (parseFloat(val)||0).toLocaleString();
    const formatDate = dateStr => {
        if (!dateStr) return '-';
        if (dateStr.includes('T')) dateStr = dateStr.split('T')[0];
        return dateStr;
    };

    // ===============================
    // Expose Global Functions
    // ===============================
    window.downloadPDF = downloadPDF;
    window.generateReport = generateReport;
})();
